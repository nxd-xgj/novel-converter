<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="小说编码转换"
            android:textSize="20sp"
            android:textColor="@color/on_surface"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="纯本地处理 · 不上传服务器 · 离线可用"
            android:textSize="12sp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginTop="2dp" />

        <!-- 文件选择区 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 拖拽/选择区 -->
                <LinearLayout
                    android:id="@+id/dropZone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:background="@drawable/bg_drop_zone"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击选择 TXT 文件"
                        android:textSize="16sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="批量支持 · 自动检测编码 · 输出纯 GBK"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- 文件列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/fileList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <!-- 操作栏 -->
                <LinearLayout
                    android:id="@+id/actionBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="14dp"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConvert"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="开始转换"
                        android:textSize="13sp"
                        app:cornerRadius="8dp"
                        app:backgroundTint="@color/primary"
                        android:textColor="@color/on_surface"
                        android:enabled="false" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <CheckBox
                            android:id="@+id/optCompact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="压缩空行"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant"
                            android:checked="true"
                            android:buttonTint="@color/primary" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <CheckBox
                                android:id="@+id/optSplit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="分卷每 "
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant"
                                android:buttonTint="@color/primary" />

                            <EditText
                                android:id="@+id/optSplitMB"
                                android:layout_width="48dp"
                                android:layout_height="32dp"
                                android:text="4"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface"
                                android:background="@drawable/bg_input"
                                android:gravity="center"
                                android:inputType="number"
                                android:enabled="false" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" MB"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClear"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="12dp"
                        android:text="清空"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        app:strokeColor="@color/outline"
                        app:cornerRadius="8dp" />
                </LinearLayout>

                <!-- 进度条 -->
                <ProgressBar
                    android:id="@+id/progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/outline" />

                <!-- 结果 -->
                <TextView
                    android:id="@+id/result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textSize="12sp"
                    android:textColor="@color/success"
                    android:visibility="gone" />

                <!-- 统计 -->
                <LinearLayout
                    android:id="@+id/stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/statsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 功能说明 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="功能说明"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="▸ 自动检测编码：UTF-8、GBK、GB2312、GB18030、BIG5 等\n▸ 输出纯 GBK：所有 GBK 不支持的字符自动丢弃\n▸ 效率：10MB 小说 ~2 秒转换完成\n▸ 离线运行：无需联网，纯本地处理"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 调试日志面板 -->
        <LinearLayout
            android:id="@+id/debugPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleDebug"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🐛 调试日志 ▽"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_variant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopyLog"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="📋 复制"
                    android:textSize="11sp"
                    android:textColor="@color/accent_blue" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_variant"
                app:cardCornerRadius="6dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/outline"
                app:strokeWidth="1dp">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/debugLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textIsSelectable="true"
                        android:fontFamily="monospace"
                        android:textSize="10sp"
                        android:textColor="#80E0E0F0"
                        android:lineSpacingExtra="2dp" />
                </ScrollView>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
